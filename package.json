{
  "name": "compact-mobile-keyboard",
  "version": "1.0.0",
  "description": "Ultra-compact mobile keyboard - all letters in minimal vertical space",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "style": "dist/index.esm.css",
  "sideEffects": [
    "dist/styles.css",
    "dist/index.esm.css",
    "dist/index.esm.js",
    "dist/keyboard.js"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "style": "./dist/index.esm.css",
      "default": "./dist/index.esm.js"
    },
    "./dist/index.esm.css": "./dist/index.esm.css"
  },
  "scripts": {
    "build": "tsc && esbuild src/index.ts --bundle --format=esm --outfile=dist/index.esm.js --external:react --external:react-dom && node scripts/inject-css.js",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "keywords": ["keyboard", "mobile", "compact", "input", "virtual-keyboard"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "esbuild": "^0.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}